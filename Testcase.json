          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Booking 1 Created Successfully\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "const response = pm.response.json();",
              "pm.environment.set(\"USER_BOOKING_ID\", response.data._id);",
              "// เก็บ booking นี้ไว้ให้ admin ใช้ด้วย (จะไม่ถูกลบโดย user)",
              "pm.environment.set(\"ADMIN_TARGET_BOOKING_ID\", response.data._id);",
              "pm.execution.setNextRequest(\"Create 2nd Booking\");"
