    {
      "name": "View Companies",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "const response = pm.response.json();\r",
              "pm.test(\"There are some companies available\", () => {\r",
              "    pm.expect(response.count).to.be.above(0);\r",
              "});\r",
              "// ดึง ID บริษัทแรกมาเก็บไว้จองคิว\r",
              "pm.environment.set(\"COMPANY_ID\", response.data[0]._id);\r",
              "pm.execution.setNextRequest(\"Create 1st Booking\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{URL}}/api/v1/companies",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "v1",
            "companies"
          ]
        },
        "description": "fetch all hospitals from database"
      },
      "response": []
    },
