    {
      "name": "Normal User Register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 or 201 (Created)\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "pm.execution.setNextRequest(\"Normal User Login\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"TEST_EMAIL\", pm.variables.replaceIn('{{$randomEmail}}'));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "description": "JSON Type",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \"name\": \"{{$randomFullName}}\",\r\n    \"telephone_number\": \"0812345678\",\r\n    \"email\": \"{{TEST_EMAIL}}\",\r\n    \"password\": \"password123\",\r\n    \"role\": \"user\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{URL}}/api/v1/auth/register",
          "host": [
            "{{URL}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "register"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Normal User Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 (Login Success)\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "const response = pm.response.json();\r",
              "pm.test(\"Token is generated\", function () {\r",
              "    pm.expect(response).to.have.property('token');\r",
              "});\r",
              "// เก็บ Token และส่งไม้ต่อ\r",
              "pm.environment.set(\"TOKEN\", response.token);\r",
              "pm.execution.setNextRequest(\"View Companies\");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
